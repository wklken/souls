---
layout: null
---
[
  {% assign souls = site.pages | where: 'layout', 'soul' %}
  {% for soul in souls %}
  {
    "name": "{{ soul.title | escape }}",
    "name_en": "{{ soul.english_name | escape }}",
    "url": "{{ soul.url | relative_url }}",
    "category": "{{ soul.category_name | escape }}",
    "tags": {{ soul.tags | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
